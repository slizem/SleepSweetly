<Window x:Class="SleepSweetly.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:SleepSweetly.Infrastructure.Converters"
        Title="SleepSweetly" Height="500" Width="320"
        WindowStartupLocation="Manual" ResizeMode="NoResize"
        Background="Transparent" AllowsTransparency="True" WindowStyle="None"
        Topmost="False" ShowInTaskbar="False">

    <Window.Resources>
        <c:BoolToVisibilityConverter x:Key="B2V"/>
        <c:InverseBoolConverter x:Key="InvB"/>
        <c:PowerCategoryToTextConverter x:Key="CatConv"/>
        <c:CollectionEmptyToVisibilityConverter x:Key="EmptyConv"/>

        <SolidColorBrush x:Key="BgBrush" Color="#CC0D0D0D"/>
        <SolidColorBrush x:Key="CardBrush" Color="#440D0D0D"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#808080"/>
        <SolidColorBrush x:Key="Accent" Color="#2ECC71"/>
        <SolidColorBrush x:Key="Warning" Color="#E74C3C"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#2A2A2A"/>

        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ReqTemplate">
            <Border Background="{StaticResource CardBrush}" CornerRadius="6" Margin="0,0,0,4" Padding="10,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding DisplayName}" 
                               Foreground="{StaticResource Warning}" 
                               FontSize="10.5" FontFamily="Consolas" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="1" Text="{Binding Category, Converter={StaticResource CatConv}}" 
                               Foreground="{StaticResource TextSecondary}" FontSize="8" Margin="0,3,0,0"
                               Visibility="{Binding Category, Converter={StaticResource B2V}}"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border Background="{StaticResource BgBrush}" CornerRadius="14" 
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            MouseLeftButtonDown="OnMouseLeftButtonDown">

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="(ᴗ˳ᴗ)ᶻ𝗓𐰁" FontSize="28" 
                               FontWeight="Light" Foreground="{StaticResource Accent}"/>
                    <TextBlock Text="Блокировки сна" FontSize="11" 
                               Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Width="28" Height="28" Content="—" 
                        FontSize="14" Style="{StaticResource FlatBtn}" 
                        Command="{Binding ToggleWindowCommand}"/>
            </Grid>

            <Border Grid.Row="1" Background="{StaticResource CardBrush}" 
                    CornerRadius="8" Padding="12,8" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding StatusText}" 
                               FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}"/>
                    <Button Grid.Column="1" Content="↻" Width="28" Height="28" 
                            FontSize="16" FontWeight="Bold" Style="{StaticResource FlatBtn}" 
                            Command="{Binding RefreshCommand}" 
                            IsEnabled="{Binding IsScanning, Converter={StaticResource InvB}}"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding BlockingRequests}" 
                      ItemTemplate="{StaticResource ReqTemplate}"/>

                    <Border Background="{StaticResource CardBrush}" 
                CornerRadius="8" 
                Padding="16"
                Visibility="{Binding BlockingRequests.Count, Converter={StaticResource EmptyConv}}">
                        <TextBlock Text="Процессы, блокирующие сон, не обнаружены" 
                       Foreground="{StaticResource TextSecondary}" 
                       FontSize="11" 
                       TextAlignment="Center"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <TextBlock Grid.Row="3" Text="{Binding LastUpdateText}" 
                       Foreground="{StaticResource TextSecondary}" 
                       FontSize="9" HorizontalAlignment="Right"/>
        </Grid>
    </Border>
</Window>